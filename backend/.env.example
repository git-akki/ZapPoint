# MongoDB connection string (Atlas or local mongod)
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/zappoint

# JWT secret — at least 32 random chars (use `openssl rand -hex 32`)
JWT_SECRET=replace-with-long-random-string

# Server port (Render uses 10000 by default)
PORT=5000

# Allowed origins for CORS (comma-separated). Add your Vercel URL after deploy.
CORS_ORIGINS=http://localhost:5173,https://zap-point-m4cq.vercel.app

# Gmail SMTP for welcome emails (use an App Password, not your Google password)
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-16-char-app-password

# Production-only: enable the self-ping keep-alive
NODE_ENV=development
